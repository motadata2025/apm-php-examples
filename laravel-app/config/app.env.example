# Laravel Application - Configuration Template
# Copy this file to app.env and customize for your environment
# This file serves as the SINGLE SOURCE OF TRUTH for all application configuration

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME="Laravel"
APP_PORT=8004
NETWORK_INTERFACE="0.0.0.0"
NETWORK_DISPLAY="all interfaces (dynamic IP safe)"
PUBLIC_IP="auto-detected"
PHP_VERSION="8.4"
DEPLOYMENT_TYPE="apache-fpm"
DEPLOYMENT_DESC="Apache with PHP-FPM"

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
APP_ENV=production
APP_DEBUG=false

# =============================================================================
# DATABASE CONFIGURATION (Laravel App - Standardized Ports)
# =============================================================================
# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3311
MYSQL_DATABASE=laravel_app_db
MYSQL_USERNAME=root
MYSQL_PASSWORD=rootpassword

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5437
POSTGRES_DATABASE=laravel_app_db
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgrespassword

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6384

# =============================================================================
# WEB SERVER CONFIGURATION
# =============================================================================
APACHE_APP_DIR="/var/www/laravel-app"

# =============================================================================
# LARAVEL-SPECIFIC CONFIGURATION
# =============================================================================
LARAVEL_APP_KEY=
LARAVEL_APP_URL=http://localhost:8004
LARAVEL_DB_CONNECTION=mysql
LARAVEL_CACHE_DRIVER=redis
LARAVEL_SESSION_DRIVER=redis
LARAVEL_QUEUE_CONNECTION=redis

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
DEV_SERVER_HOST=localhost
DEV_SERVER_PORT=8004

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
PRODUCTION_CACHE_DRIVER=redis
PRODUCTION_SESSION_DRIVER=redis
PRODUCTION_QUEUE_DRIVER=redis

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
SECURE_HEADERS=true
CSRF_PROTECTION=true
XSS_PROTECTION=true

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_CHANNEL=stack
MONITORING_ENABLED=true

# =============================================================================
# USAGE INSTRUCTIONS
# =============================================================================
# 1. Copy this file: cp config/app.env.example config/app.env
# 2. Run setup: make setup
# 3. Configure: make compile (interactive configuration)
# 4. Start app: make start
# 5. Check status: make status
#
# Laravel-specific commands:
# - make artisan (Laravel Artisan CLI)
# - make dev (Laravel development server)
# - make test (Laravel testing with Artisan)
#
# For advanced configuration:
# - Edit config/app.env directly
# - Run 'make stop && make start' to apply changes
