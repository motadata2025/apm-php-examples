APP_ENV=production
APP_DEBUG=false

# Database Configuration (Docker services) - ISOLATED
DB_HOST=127.0.0.1
DB_PORT=3308
DB_DATABASE=symfony_app_db
DB_USERNAME=root
DB_PASSWORD=rootpassword

# MySQL Configuration (Docker services) - ISOLATED  
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3308
MYSQL_DATABASE=symfony_app_db
MYSQL_USERNAME=root
MYSQL_PASSWORD=rootpassword

# PostgreSQL Configuration (Docker services) - ISOLATED
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5434
POSTGRES_DATABASE=symfony_app_db
POSTGRES_USERNAME=symfony_app_user
POSTGRES_PASSWORD=symfony_app_password

# Redis Configuration (Docker services) - ISOLATED
REDIS_HOST=127.0.0.1
REDIS_PORT=6381
REDIS_PASSWORD=

# Production Database Connection Scaling
# Optimized for 200+ concurrent users

# MySQL Connection Pool Settings
MYSQL_MAX_CONNECTIONS=100
MYSQL_CONNECT_TIMEOUT=10
MYSQL_WAIT_TIMEOUT=600
MYSQL_INTERACTIVE_TIMEOUT=600

# PostgreSQL Connection Pool Settings
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=4MB

# Redis Connection Pool Settings
REDIS_MAX_CONNECTIONS=50
REDIS_TIMEOUT=5
REDIS_TCP_KEEPALIVE=60

# Application Performance Settings
APP_CACHE_DRIVER=redis
APP_SESSION_DRIVER=redis
APP_QUEUE_DRIVER=redis
APP_LOG_LEVEL=warning

# Symfony Messenger Configuration (Queue System)
MESSENGER_TRANSPORT_DSN=redis://127.0.0.1:6382/messages

