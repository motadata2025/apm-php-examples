# Symfony Application - Configuration Template
# Copy this file to app.env and customize for your environment
# This file serves as the SINGLE SOURCE OF TRUTH for all application configuration

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME="Symfony"
APP_PORT=8002
NETWORK_INTERFACE="0.0.0.0"
NETWORK_DISPLAY="all interfaces (dynamic IP safe)"
PUBLIC_IP="auto-detected"
PHP_VERSION="8.4"
DEPLOYMENT_TYPE="apache-fpm"
DEPLOYMENT_DESC="Apache with PHP-FPM"

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
APP_ENV=production
APP_DEBUG=false

# =============================================================================
# DATABASE CONFIGURATION (Symfony App - Standardized Ports)
# =============================================================================
# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3308
MYSQL_DATABASE=symfony_app_db
MYSQL_USERNAME=root
MYSQL_PASSWORD=rootpassword

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DATABASE=symfony_app_db
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgrespassword

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6381

# =============================================================================
# WEB SERVER CONFIGURATION
# =============================================================================
APACHE_APP_DIR="/var/www/symfony-app"

# =============================================================================
# SYMFONY-SPECIFIC CONFIGURATION
# =============================================================================
SYMFONY_APP_SECRET=
SYMFONY_DATABASE_URL=mysql://root:rootpassword@localhost:3308/symfony_app_db
SYMFONY_REDIS_URL=redis://localhost:6381
SYMFONY_CACHE_DRIVER=redis
SYMFONY_SESSION_DRIVER=redis

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
DEV_SERVER_HOST=localhost
DEV_SERVER_PORT=8002

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
PRODUCTION_CACHE_DRIVER=redis
PRODUCTION_SESSION_DRIVER=redis
PRODUCTION_QUEUE_DRIVER=redis

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
SECURE_HEADERS=true
CSRF_PROTECTION=true
XSS_PROTECTION=true

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_CHANNEL=stack
MONITORING_ENABLED=true

# =============================================================================
# USAGE INSTRUCTIONS
# =============================================================================
# 1. Copy this file: cp config/app.env.example config/app.env
# 2. Run setup: make setup
# 3. Configure: make compile (interactive configuration)
# 4. Start app: make start
# 5. Check status: make status
#
# Symfony-specific commands:
# - make console (Symfony Console CLI)
# - make php-status (PHP version diagnostics)
# - make network-status (Network configuration diagnostics)
#
# For advanced configuration:
# - Edit config/app.env directly
# - Run 'make stop && make start' to apply changes
