<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Symfony APM Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container mt-4">
        <header class="text-center mb-5">
            <h1 class="display-4 text-primary">Symfony APM Dashboard</h1>
            <p class="lead">Application Performance Monitoring & Testing Interface</p>
        </header>

        <div class="row g-4">
            <!-- Block 1: Application Information -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-primary">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0">Application Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <strong>Application Type:</strong>
                            <span class="badge bg-primary ms-2">{{ app_name }}</span>
                        </div>
                        <div class="mb-3">
                            <strong>Running PHP Version:</strong>
                            <span class="badge bg-success ms-2">{{ php_version }}</span>
                        </div>
                        <div class="mb-3">
                            <strong>Web Server:</strong>
                            <span class="badge bg-info ms-2">{{ web_server }}</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Block 2: External API & Database Operations -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-warning">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="card-title mb-0">External API & Database</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <button class="btn btn-outline-primary w-100" onclick="testExternalApi()">
                                <span class="spinner-border spinner-border-sm d-none" id="external-spinner"></span>
                                External API
                            </button>
                        </div>
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-warning" onclick="testDbConnection()">
                                <span class="spinner-border spinner-border-sm d-none" id="db-check-spinner"></span>
                                Connection Check
                            </button>
                            <button class="btn btn-outline-warning" onclick="testDbCrud()">
                                <span class="spinner-border spinner-border-sm d-none" id="db-crud-spinner"></span>
                                DB Calls
                            </button>
                        </div>
                        <div id="db-result" class="mt-3 result-panel"></div>
                    </div>
                </div>
            </div>

            <!-- Block 3: Redis Cache Operations -->
            <div class="col-lg-4 col-md-12">
                <div class="card h-100 border-success">
                    <div class="card-header bg-success text-white">
                        <h5 class="card-title mb-0">Redis Cache</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-success btn-sm" onclick="redisInsert3()">
                                <span class="spinner-border spinner-border-sm d-none" id="redis-push-spinner"></span>
                                Insert 3
                            </button>
                            <button class="btn btn-outline-success btn-sm" onclick="redisInsert1()">
                                <span class="spinner-border spinner-border-sm d-none" id="redis-push-one-spinner"></span>
                                Insert 1 & count
                            </button>
                            <button class="btn btn-outline-success btn-sm" onclick="redisReadRemove()">
                                <span class="spinner-border spinner-border-sm d-none" id="redis-pop-spinner"></span>
                                Read & remove
                            </button>
                            <button class="btn btn-outline-danger btn-sm" onclick="redisClearQueue()">
                                <span class="spinner-border spinner-border-sm d-none" id="redis-clear-spinner"></span>
                                Clear Queue
                            </button>
                        </div>
                        <div id="redis-result" class="mt-3 result-panel"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Toast container -->
        <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toast-container"></div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Utility functions
        function showSpinner(spinnerId) {
            const spinner = document.getElementById(spinnerId);
            if (spinner) spinner.classList.remove('d-none');
        }

        function hideSpinner(spinnerId) {
            const spinner = document.getElementById(spinnerId);
            if (spinner) spinner.classList.add('d-none');
        }

        function showToast(message, type = 'info') {
            const toastContainer = document.getElementById('toast-container');
            const toastId = 'toast-' + Date.now();
            
            const bgClass = type === 'success' ? 'bg-success' : 
                           type === 'error' ? 'bg-danger' : 
                           type === 'warning' ? 'bg-warning' : 'bg-info';
            
            const toastHtml = `
                <div class="toast ${bgClass} text-white" id="${toastId}" role="alert">
                    <div class="toast-header ${bgClass} text-white border-0">
                        <strong class="me-auto">Notification</strong>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                    </div>
                    <div class="toast-body">${message}</div>
                </div>
            `;
            
            toastContainer.insertAdjacentHTML('beforeend', toastHtml);
            
            const toastElement = document.getElementById(toastId);
            const toast = new bootstrap.Toast(toastElement, { delay: 5000 });
            toast.show();
            
            toastElement.addEventListener('hidden.bs.toast', () => {
                toastElement.remove();
            });
        }

        function updateResultPanel(panelId, content, isError = false) {
            const panel = document.getElementById(panelId);
            if (panel) {
                panel.innerHTML = `<div class="alert ${isError ? 'alert-danger' : 'alert-success'} alert-sm">${content}</div>`;
            }
        }

        // API call wrapper
        async function apiCall(endpoint, spinnerId) {
            showSpinner(spinnerId);
            
            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                const data = await response.json();
                
                if (!response.ok) {
                    throw new Error(data.error || `HTTP ${response.status}`);
                }
                
                return data;
            } finally {
                hideSpinner(spinnerId);
            }
        }

        // External API test
        async function testExternalApi() {
            try {
                const result = await apiCall('/api/external', 'external-spinner');
                
                if (result.status === 'success') {
                    const duration = result.response.duration_ms;
                    showToast(`External API test successful (${duration}ms)`, 'success');
                } else {
                    throw new Error(result.error || 'External API test failed');
                }
            } catch (error) {
                showToast(`External API test failed: ${error.message}`, 'error');
            }
        }

        // Database connection test
        async function testDbConnection() {
            try {
                const result = await apiCall('/api/db/check', 'db-check-spinner');
                
                const message = `MySQL: ${result.mysql}, PostgreSQL: ${result.pgsql}`;
                updateResultPanel('db-result', message);
                showToast('Database connection test completed', 'success');
            } catch (error) {
                updateResultPanel('db-result', `Error: ${error.message}`, true);
                showToast(`Database connection test failed: ${error.message}`, 'error');
            }
        }

        // Database CRUD operations
        async function testDbCrud() {
            try {
                const result = await apiCall('/api/db/crud', 'db-crud-spinner');
                
                const mysqlInfo = result.mysql.created_id ? `MySQL ID: ${result.mysql.created_id}` : 'MySQL: Error';
                const pgsqlInfo = result.pgsql.created_id ? `PG ID: ${result.pgsql.created_id}` : 'PG: Error';
                const message = `${mysqlInfo}, ${pgsqlInfo}`;
                updateResultPanel('db-result', message);
                showToast('Database CRUD operations completed', 'success');
            } catch (error) {
                updateResultPanel('db-result', `Error: ${error.message}`, true);
                showToast(`Database CRUD operations failed: ${error.message}`, 'error');
            }
        }

        // Redis operations
        async function redisInsert3() {
            try {
                const result = await apiCall('/api/redis/push', 'redis-push-spinner');
                
                if (result.status === 'success') {
                    const message = `Inserted 3 items. Queue length: ${result.queue_length}`;
                    updateResultPanel('redis-result', message);
                    showToast(`Inserted 3 items. Queue length: ${result.queue_length}`, 'success');
                } else {
                    throw new Error(result.error || 'Redis insert failed');
                }
            } catch (error) {
                updateResultPanel('redis-result', `Error: ${error.message}`, true);
                showToast(`Redis insert failed: ${error.message}`, 'error');
            }
        }

        async function redisInsert1() {
            try {
                const result = await apiCall('/api/redis/push_one', 'redis-push-one-spinner');
                
                if (result.status === 'success') {
                    const message = `Inserted 1 item. Queue length: ${result.queue_length}`;
                    updateResultPanel('redis-result', message);
                    showToast(`Inserted 1 item. Queue length: ${result.queue_length}`, 'success');
                } else {
                    throw new Error(result.error || 'Redis insert failed');
                }
            } catch (error) {
                updateResultPanel('redis-result', `Error: ${error.message}`, true);
                showToast(`Redis insert failed: ${error.message}`, 'error');
            }
        }

        async function redisReadRemove() {
            try {
                const result = await apiCall('/api/redis/pop', 'redis-pop-spinner');
                
                if (result.status === 'success') {
                    if (result.popped_value) {
                        const message = `Read: ${result.popped_value.substring(0, 30)}... Remaining: ${result.queue_length}`;
                        updateResultPanel('redis-result', message);
                        showToast(`Read 1 item. Remaining: ${result.queue_length}`, 'success');
                    } else {
                        updateResultPanel('redis-result', 'Queue is empty');
                        showToast('Queue is empty', 'warning');
                    }
                } else {
                    throw new Error(result.error || 'Redis read failed');
                }
            } catch (error) {
                updateResultPanel('redis-result', `Error: ${error.message}`, true);
                showToast(`Redis read failed: ${error.message}`, 'error');
            }
        }

        async function redisClearQueue() {
            try {
                const result = await apiCall('/api/redis/clear', 'redis-clear-spinner');
                
                if (result.status === 'success') {
                    const message = `Cleared queue. Previous length: ${result.cleared_count}`;
                    updateResultPanel('redis-result', message);
                    showToast(`Queue cleared. Previous length: ${result.cleared_count}`, 'success');
                } else {
                    throw new Error(result.error || 'Redis clear failed');
                }
            } catch (error) {
                updateResultPanel('redis-result', `Error: ${error.message}`, true);
                showToast(`Redis clear failed: ${error.message}`, 'error');
            }
        }

        // Initialize dashboard
        document.addEventListener('DOMContentLoaded', function() {
            showToast('Symfony APM Dashboard loaded', 'success');
        });
    </script>
</body>
</html>
