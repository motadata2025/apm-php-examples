# PHPStan Configuration Template for APM PHP Examples
# Provides maximum static analysis coverage

parameters:
    level: 8
    paths:
        - public
        - src
        - public
        - src
        - lib
        - app
    
    excludePaths:
        - vendor
        - tests
        - var/cache
        - storage
        - bootstrap/cache
    
    ignoreErrors: []
    
    checkMissingIterableValueType: true
    checkGenericClassInNonGenericObjectType: true
    reportUnmatchedIgnoredErrors: true
    
    # Enable bleeding edge features
    treatPhpDocTypesAsCertain: false
    
    # Memory limit for analysis
    memoryLimitFile: 1G
    
    # Parallel processing
    parallel:
        jobSize: 20
        maximumNumberOfProcesses: 32
        minimumNumberOfJobsPerProcess: 2
    
    typeAliases:
        UserId: 'int<1, max>'
        Email: 'non-empty-string'
        
    # Stub files for better analysis
    stubFiles:
        # Add framework-specific stubs if needed
    
    # Bootstrap file for constants/functions
    bootstrapFiles:
        # Add if needed per application
