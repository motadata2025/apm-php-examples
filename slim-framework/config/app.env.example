# Simple PHP Application - Standardized Configuration Template
# Copy this file to app.env and customize for your environment
# This file serves as the SINGLE SOURCE OF TRUTH for all application configuration

# =============================================================================
# CONFIGURATION METADATA
# =============================================================================
CONFIG_VERSION="3.0"
CONFIG_GENERATED_BY="standardized_template"
CONFIG_LAST_UPDATED="2025-09-01 04:07:37"
CONFIG_APP="simple-php"

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME="Simple PHP"
APP_PORT=8001
NETWORK_INTERFACE="0.0.0.0"
NETWORK_DISPLAY="all interfaces (dynamic IP safe)"
PUBLIC_IP="auto-detected"
PHP_VERSION="8.4"
DEPLOYMENT_TYPE="apache-fpm"
DEPLOYMENT_DESC="Apache with PHP-FPM"

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
APP_ENV=production
APP_DEBUG=false

# =============================================================================
# DATABASE CONFIGURATION (Simple PHP - Standardized Ports)
# =============================================================================
# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3309
MYSQL_DATABASE=slim_framework_db
MYSQL_USERNAME=root
MYSQL_PASSWORD=rootpassword

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_DATABASE=slim_framework_db
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgrespassword

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6382

# =============================================================================
# WEB SERVER CONFIGURATION
# =============================================================================
APACHE_APP_DIR="/var/www/simple-php"
NGINX_APP_DIR="/var/www/simple-php"
PHP_FPM_SOCKET="/run/php/php8.4-fpm.sock"

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
DOCKER_COMPOSE_CMD="docker compose"
DOCKER_NETWORK="simple-php_network"
DOCKER_MYSQL_PORT=3309
DOCKER_POSTGRES_PORT=5435
DOCKER_REDIS_PORT=6382

# =============================================================================
# FRAMEWORK-SPECIFIC CONFIGURATION
# =============================================================================


# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
DEV_SERVER_HOST=localhost
DEV_SERVER_PORT=8000

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
PRODUCTION_CACHE_DRIVER=redis
PRODUCTION_SESSION_DRIVER=redis
PRODUCTION_QUEUE_DRIVER=redis

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
SECURE_HEADERS=true
CSRF_PROTECTION=true
XSS_PROTECTION=true
ALLOW_PUBLIC=false
ENABLE_HTTPS=false
CONFIGURE_FIREWALL=false

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_CHANNEL=stack
MONITORING_ENABLED=true
LOG_FILE="logs/application.log"

# =============================================================================
# RESOURCE LIMITS
# =============================================================================
PHP_MEMORY_LIMIT="256M"
PHP_MAX_EXECUTION_TIME=30
COMPOSER_MEMORY_LIMIT="2G"

# =============================================================================
# CACHE AND CLEANUP SETTINGS
# =============================================================================
CLEAR_CACHE=false
REMOVE_VOLUMES=false
CACHE_TIMEOUT=3600

# =============================================================================
# TIMEOUT SETTINGS
# =============================================================================
DOCKER_HEALTH_TIMEOUT=120
CONTAINER_START_TIMEOUT=60
APPLICATION_START_TIMEOUT=30

# =============================================================================
# STANDARDIZED USAGE INSTRUCTIONS
# =============================================================================
# 1. Copy this file: cp config/app.env.example config/app.env
# 2. Run setup: make setup
# 3. Configure: make compile (interactive configuration wizard)
# 4. Start app: make start
# 5. Check status: make status
#
# Standardized commands across all applications:
# - make setup         (system requirements and Docker setup)
# - make compile       (interactive configuration)
# - make start         (deploy and start application)
# - make status        (comprehensive status with resource monitoring)
# - make php-status    (PHP diagnostics)
# - make network-status (network diagnostics)
# - make disable       (disable web server virtual host)
# - make enable        (enable web server virtual host)
# - make stop          (stop application and cleanup)
# - make down          (complete cleanup)
#

#
# Advanced configuration:
# - Edit config/app.env directly for custom settings
# - Run 'make stop && make start' to apply changes
# - Use environment variables for overrides:
#   VERBOSE=1 make setup           (detailed logging)
#   CLEAR_CACHE=1 make stop        (clear cache on stop)
#   REMOVE_VOLUMES=1 make down     (remove data volumes)
#   PHP_VERSION=8.3 make compile   (override PHP version)
#
# Port allocation (standardized across all applications):
# - simple-php:      8000, MySQL:3307, PostgreSQL:5433, Redis:6380
# - slim-framework:  8001, MySQL:3309, PostgreSQL:5435, Redis:6382
# - symfony-app:     8002, MySQL:3308, PostgreSQL:5434, Redis:6381
# - codeigniter-app: 8003, MySQL:3310, PostgreSQL:5436, Redis:6383
# - laravel-app:     8004, MySQL:3311, PostgreSQL:5437, Redis:6384
#
# Security considerations:
# - Change default database passwords in production
# - Set ALLOW_PUBLIC=true only when external access is required
# - Use ENABLE_HTTPS=true for production deployments
# - Configure firewall rules with CONFIGURE_FIREWALL=true
#
# Troubleshooting:
# - Check logs: tail -f logs/application.log
# - Validate config: make status
# - PHP diagnostics: make php-status
# - Network issues: make network-status
# - Docker issues: docker ps -a && docker compose logs
