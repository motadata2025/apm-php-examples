{
    "name": "apm/slim-framework-app",
    "description": "Slim Framework APM Application with database and Redis operations",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.6",
        "vlucas/phpdotenv": "^5.5",
        "predis/predis": "^2.0"
    },
    "require-dev": {
        "symfony/var-dumper": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "start": "php -S 0.0.0.0:8083 -t public"
    }
}
