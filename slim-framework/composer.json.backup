{
    "name": "apm-php-examples/slim-framework",
    "type": "project",
    "description": "Slim Framework application for APM testing",
    "keywords": ["slim", "framework", "apm", "monitoring", "microframework"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "slim/http": "^1.3",
        "slim/twig-view": "^3.3",
        "guzzlehttp/guzzle": "^7.2",
        "monolog/monolog": "^3.0",
        "php-di/php-di": "^7.0",

        "predis/predis": "^2.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Lib\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}