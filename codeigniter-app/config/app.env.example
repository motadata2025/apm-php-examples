# CodeIgniter Application - Configuration Template
# Copy this file to app.env and customize for your environment
# This file serves as the SINGLE SOURCE OF TRUTH for all application configuration

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME="CodeIgniter"
APP_PORT=8003
NETWORK_INTERFACE="0.0.0.0"
NETWORK_DISPLAY="all interfaces (dynamic IP safe)"
PUBLIC_IP="auto-detected"
PHP_VERSION="8.4"
DEPLOYMENT_TYPE="apache-fpm"
DEPLOYMENT_DESC="Apache with PHP-FPM"

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
APP_ENV=production
APP_DEBUG=false

# =============================================================================
# DATABASE CONFIGURATION (CodeIgniter App - Standardized Ports)
# =============================================================================
# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3310
MYSQL_DATABASE=codeigniter_app_db
MYSQL_USERNAME=root
MYSQL_PASSWORD=rootpassword

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5436
POSTGRES_DATABASE=codeigniter_app_db
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgrespassword

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6383

# =============================================================================
# WEB SERVER CONFIGURATION
# =============================================================================
APACHE_APP_DIR="/var/www/codeigniter-app"

# =============================================================================
# CODEIGNITER-SPECIFIC CONFIGURATION
# =============================================================================
CI_ENVIRONMENT=production
CI_BASE_URL=http://localhost:8003
CI_DATABASE_DEFAULT_HOSTNAME=localhost
CI_DATABASE_DEFAULT_PORT=3310
CI_DATABASE_DEFAULT_DATABASE=codeigniter_app_db
CI_DATABASE_DEFAULT_USERNAME=root
CI_DATABASE_DEFAULT_PASSWORD=rootpassword

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
DEV_SERVER_HOST=localhost
DEV_SERVER_PORT=8003

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
PRODUCTION_CACHE_DRIVER=redis
PRODUCTION_SESSION_DRIVER=redis

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
SECURE_HEADERS=true
CSRF_PROTECTION=true
XSS_PROTECTION=true

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_CHANNEL=stack
MONITORING_ENABLED=true

# =============================================================================
# USAGE INSTRUCTIONS
# =============================================================================
# 1. Copy this file: cp config/app.env.example config/app.env
# 2. Run setup: make setup
# 3. Configure: make compile (interactive configuration)
# 4. Start app: make start
# 5. Check status: make status
#
# CodeIgniter-specific commands:
# - make spark (CodeIgniter Spark CLI)
# - make dev (CodeIgniter development server)
# - make php-status (PHP version diagnostics)
# - make network-status (Network configuration diagnostics)
#
# For advanced configuration:
# - Edit config/app.env directly
# - Run 'make stop && make start' to apply changes
