{
    "name": "apm/codeigniter-app",
    "description": "CodeIgniter APM Application with PHP 8.1 timezone fix support",
    "type": "project",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "predis/predis": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
