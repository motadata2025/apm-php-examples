# Simple PHP Application Environment Configuration
# Copy this file to .env and modify the values as needed

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_ENV=production
APP_DEBUG=false

# =============================================================================
# DATABASE CONFIGURATION (Simple PHP - Port 8000)
# =============================================================================

# Primary Database (MySQL) - Port 3307
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=simple_php_db
DB_USERNAME=root
DB_PASSWORD=rootpassword

# MySQL Configuration (Docker services)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_DATABASE=simple_php_db
MYSQL_USERNAME=root
MYSQL_PASSWORD=rootpassword

# PostgreSQL Configuration (Docker services) - Port 5433
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DATABASE=simple_php_db
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgrespassword

# Redis Configuration (Docker services) - Port 6380
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# =============================================================================
# PRODUCTION DATABASE CONNECTION SCALING
# =============================================================================
# Optimized for 200+ concurrent users

# MySQL Connection Pool Settings
MYSQL_MAX_CONNECTIONS=100
MYSQL_CONNECT_TIMEOUT=10
MYSQL_WAIT_TIMEOUT=600
MYSQL_INTERACTIVE_TIMEOUT=600

# PostgreSQL Connection Pool Settings
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=4MB

# Redis Connection Pool Settings
REDIS_MAX_CONNECTIONS=50
REDIS_TIMEOUT=5
REDIS_TCP_KEEPALIVE=60

# =============================================================================
# APPLICATION PERFORMANCE SETTINGS
# =============================================================================
APP_CACHE_DRIVER=redis
APP_SESSION_DRIVER=redis
APP_QUEUE_DRIVER=redis
APP_LOG_LEVEL=warning
