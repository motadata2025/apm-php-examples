# Simple PHP Application - Environment Configuration
# Copy this file to .env and adjust values as needed

# Application Settings
APP_NAME="Simple PHP App"
APP_ENV=development
APP_DEBUG=true

# MySQL Database Configuration
DB_MYSQL_HOST=127.0.0.1
DB_MYSQL_PORT=3307
DB_MYSQL_DATABASE=simple_php_db
DB_MYSQL_USERNAME=simple_php_user
DB_MYSQL_PASSWORD=simple_php_password

# PostgreSQL Database Configuration  
DB_PGSQL_HOST=127.0.0.1
DB_PGSQL_PORT=5433
DB_PGSQL_DATABASE=simple_php_db
DB_PGSQL_USERNAME=postgres
DB_PGSQL_PASSWORD=postgrespassword

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DATABASE=0

# External API Configuration
HTTP_TIMEOUT=20
EXTERNAL_API_URL=https://httpbin.org/get
